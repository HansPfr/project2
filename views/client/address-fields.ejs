<div class="mb-3">
  <label class="form-label">Type</label>
  <select name="type" class="form-select">
    <option value="home" <%= (addr.type === 'home' || !addr.type) ? 'selected' : '' %>>Home</option>
    <option value="work" <%= addr.type === 'work' ? 'selected' : '' %>>Work</option>
    <option value="other" <%= addr.type === 'other' ? 'selected' : '' %>>Other</option>
  </select>
</div>
<div class="mb-3">
  <label class="form-label">Country</label>
  <select name="country" class="form-select addr-country" required>
    <option value="" <%= !addr.country ? 'selected' : '' %>>— Select —</option>
    <option value="USA"    <%= addr.country === 'USA'    ? 'selected' : '' %>>USA</option>
    <option value="Canada" <%= addr.country === 'Canada' ? 'selected' : '' %>>Canada</option>
  </select>
</div>
<div class="mb-3">
  <label class="form-label">Street <span class="text-danger">*</span></label>
  <div class="position-relative">
    <input type="text" name="street" class="form-control addr-street" value="<%= addr.street || '' %>" autocomplete="off" required>
    <div class="addr-suggestions list-group" style="display:none; position:absolute; z-index:1060; width:100%; max-height:200px; overflow-y:auto; box-shadow:0 4px 12px rgba(0,0,0,.15);"></div>
  </div>
</div>
<div class="mb-3">
  <label class="form-label">Apt, Suite, etc. <span class="text-muted">(optional)</span></label>
  <input type="text" name="street2" class="form-control" value="<%= addr.street2 || '' %>">
</div>
<div class="mb-3">
  <label class="form-label">City <span class="text-danger">*</span></label>
  <input type="text" name="city" class="form-control" value="<%= addr.city || '' %>" required>
</div>
<div class="row align-items-end">
  <div class="col mb-3">
    <label class="form-label addr-state-label">State / Province</label>
    <select name="state" class="form-select addr-state-select">
      <option value="">—</option>
      <optgroup label="US States" class="opts-usa">
        <option value="AL" <%= addr.state==='AL'?'selected':'' %>>AL - Alabama</option>
        <option value="AK" <%= addr.state==='AK'?'selected':'' %>>AK - Alaska</option>
        <option value="AZ" <%= addr.state==='AZ'?'selected':'' %>>AZ - Arizona</option>
        <option value="AR" <%= addr.state==='AR'?'selected':'' %>>AR - Arkansas</option>
        <option value="CA" <%= addr.state==='CA'?'selected':'' %>>CA - California</option>
        <option value="CO" <%= addr.state==='CO'?'selected':'' %>>CO - Colorado</option>
        <option value="CT" <%= addr.state==='CT'?'selected':'' %>>CT - Connecticut</option>
        <option value="DE" <%= addr.state==='DE'?'selected':'' %>>DE - Delaware</option>
        <option value="FL" <%= addr.state==='FL'?'selected':'' %>>FL - Florida</option>
        <option value="GA" <%= addr.state==='GA'?'selected':'' %>>GA - Georgia</option>
        <option value="HI" <%= addr.state==='HI'?'selected':'' %>>HI - Hawaii</option>
        <option value="ID" <%= addr.state==='ID'?'selected':'' %>>ID - Idaho</option>
        <option value="IL" <%= addr.state==='IL'?'selected':'' %>>IL - Illinois</option>
        <option value="IN" <%= addr.state==='IN'?'selected':'' %>>IN - Indiana</option>
        <option value="IA" <%= addr.state==='IA'?'selected':'' %>>IA - Iowa</option>
        <option value="KS" <%= addr.state==='KS'?'selected':'' %>>KS - Kansas</option>
        <option value="KY" <%= addr.state==='KY'?'selected':'' %>>KY - Kentucky</option>
        <option value="LA" <%= addr.state==='LA'?'selected':'' %>>LA - Louisiana</option>
        <option value="ME" <%= addr.state==='ME'?'selected':'' %>>ME - Maine</option>
        <option value="MD" <%= addr.state==='MD'?'selected':'' %>>MD - Maryland</option>
        <option value="MA" <%= addr.state==='MA'?'selected':'' %>>MA - Massachusetts</option>
        <option value="MI" <%= addr.state==='MI'?'selected':'' %>>MI - Michigan</option>
        <option value="MN" <%= addr.state==='MN'?'selected':'' %>>MN - Minnesota</option>
        <option value="MS" <%= addr.state==='MS'?'selected':'' %>>MS - Mississippi</option>
        <option value="MO" <%= addr.state==='MO'?'selected':'' %>>MO - Missouri</option>
        <option value="MT" <%= addr.state==='MT'?'selected':'' %>>MT - Montana</option>
        <option value="NE" <%= addr.state==='NE'?'selected':'' %>>NE - Nebraska</option>
        <option value="NV" <%= addr.state==='NV'?'selected':'' %>>NV - Nevada</option>
        <option value="NH" <%= addr.state==='NH'?'selected':'' %>>NH - New Hampshire</option>
        <option value="NJ" <%= addr.state==='NJ'?'selected':'' %>>NJ - New Jersey</option>
        <option value="NM" <%= addr.state==='NM'?'selected':'' %>>NM - New Mexico</option>
        <option value="NY" <%= addr.state==='NY'?'selected':'' %>>NY - New York</option>
        <option value="NC" <%= addr.state==='NC'?'selected':'' %>>NC - North Carolina</option>
        <option value="ND" <%= addr.state==='ND'?'selected':'' %>>ND - North Dakota</option>
        <option value="OH" <%= addr.state==='OH'?'selected':'' %>>OH - Ohio</option>
        <option value="OK" <%= addr.state==='OK'?'selected':'' %>>OK - Oklahoma</option>
        <option value="OR" <%= addr.state==='OR'?'selected':'' %>>OR - Oregon</option>
        <option value="PA" <%= addr.state==='PA'?'selected':'' %>>PA - Pennsylvania</option>
        <option value="RI" <%= addr.state==='RI'?'selected':'' %>>RI - Rhode Island</option>
        <option value="SC" <%= addr.state==='SC'?'selected':'' %>>SC - South Carolina</option>
        <option value="SD" <%= addr.state==='SD'?'selected':'' %>>SD - South Dakota</option>
        <option value="TN" <%= addr.state==='TN'?'selected':'' %>>TN - Tennessee</option>
        <option value="TX" <%= addr.state==='TX'?'selected':'' %>>TX - Texas</option>
        <option value="UT" <%= addr.state==='UT'?'selected':'' %>>UT - Utah</option>
        <option value="VT" <%= addr.state==='VT'?'selected':'' %>>VT - Vermont</option>
        <option value="VA" <%= addr.state==='VA'?'selected':'' %>>VA - Virginia</option>
        <option value="WA" <%= addr.state==='WA'?'selected':'' %>>WA - Washington</option>
        <option value="WV" <%= addr.state==='WV'?'selected':'' %>>WV - West Virginia</option>
        <option value="WI" <%= addr.state==='WI'?'selected':'' %>>WI - Wisconsin</option>
        <option value="WY" <%= addr.state==='WY'?'selected':'' %>>WY - Wyoming</option>
        <option value="DC" <%= addr.state==='DC'?'selected':'' %>>DC - District of Columbia</option>
      </optgroup>
      <optgroup label="US Territories" class="opts-usa">
        <option value="AS" <%= addr.state==='AS'?'selected':'' %>>AS - American Samoa</option>
        <option value="GU" <%= addr.state==='GU'?'selected':'' %>>GU - Guam</option>
        <option value="MP" <%= addr.state==='MP'?'selected':'' %>>MP - Northern Mariana Islands</option>
        <option value="PR" <%= addr.state==='PR'?'selected':'' %>>PR - Puerto Rico</option>
        <option value="VI" <%= addr.state==='VI'?'selected':'' %>>VI - U.S. Virgin Islands</option>
      </optgroup>
      <optgroup label="Canadian Provinces" class="opts-canada">
        <option value="AB" <%= addr.state==='AB'?'selected':'' %>>AB - Alberta</option>
        <option value="BC" <%= addr.state==='BC'?'selected':'' %>>BC - British Columbia</option>
        <option value="MB" <%= addr.state==='MB'?'selected':'' %>>MB - Manitoba</option>
        <option value="NB" <%= addr.state==='NB'?'selected':'' %>>NB - New Brunswick</option>
        <option value="NL" <%= addr.state==='NL'?'selected':'' %>>NL - Newfoundland and Labrador</option>
        <option value="NS" <%= addr.state==='NS'?'selected':'' %>>NS - Nova Scotia</option>
        <option value="NT" <%= addr.state==='NT'?'selected':'' %>>NT - Northwest Territories</option>
        <option value="NU" <%= addr.state==='NU'?'selected':'' %>>NU - Nunavut</option>
        <option value="ON" <%= addr.state==='ON'?'selected':'' %>>ON - Ontario</option>
        <option value="PE" <%= addr.state==='PE'?'selected':'' %>>PE - Prince Edward Island</option>
        <option value="QC" <%= addr.state==='QC'?'selected':'' %>>QC - Quebec</option>
        <option value="SK" <%= addr.state==='SK'?'selected':'' %>>SK - Saskatchewan</option>
        <option value="YT" <%= addr.state==='YT'?'selected':'' %>>YT - Yukon</option>
      </optgroup>
    </select>
  </div>
  <div class="col-4 mb-3">
    <label class="form-label">ZIP Code <span class="text-danger">*</span></label>
    <input type="text" name="postal_code" class="form-control" value="<%= addr.postal_code || '' %>" required>
  </div>
</div>

<script>
(function () {
  var scripts = document.querySelectorAll('script');
  var me = scripts[scripts.length - 1];
  var container = me.closest('.modal-body') || me.closest('form') || me.parentElement;

  var countryEl = container.querySelector('.addr-country');
  var stateEl   = container.querySelector('.addr-state-select');
  var labelEl   = container.querySelector('.addr-state-label');

  var usaGroups    = container.querySelectorAll('.opts-usa');
  var canadaGroups = container.querySelectorAll('.opts-canada');

  function applyCountry(country) {
    usaGroups.forEach(function(g)    { g.style.display = country === 'USA'    ? '' : 'none'; });
    canadaGroups.forEach(function(g) { g.style.display = country === 'Canada' ? '' : 'none'; });

    if (country === 'USA') {
      labelEl.textContent = 'State';
    } else if (country === 'Canada') {
      labelEl.textContent = 'Province';
    } else {
      labelEl.textContent = 'State / Province';
    }

    var usaCodes    = ['AL','AK','AZ','AR','CA','CO','CT','DE','FL','GA','HI','ID','IL','IN','IA','KS','KY','LA','ME','MD','MA','MI','MN','MS','MO','MT','NE','NV','NH','NJ','NM','NY','NC','ND','OH','OK','OR','PA','RI','SC','SD','TN','TX','UT','VT','VA','WA','WV','WI','WY','DC','AS','GU','MP','PR','VI'];
    var canadaCodes = ['AB','BC','MB','NB','NL','NS','NT','NU','ON','PE','QC','SK','YT'];
    var cur = stateEl.value;
    if (country === 'USA'    && canadaCodes.indexOf(cur) !== -1) stateEl.value = '';
    if (country === 'Canada' && usaCodes.indexOf(cur)    !== -1) stateEl.value = '';
  }

  applyCountry(countryEl.value);
  countryEl.addEventListener('change', function () { applyCountry(this.value); });

  // --- Street autocomplete ---
  var streetInput   = container.querySelector('.addr-street');
  var suggestionsEl = container.querySelector('.addr-suggestions');
  var cityEl        = container.querySelector('[name="city"]');
  var postalEl      = container.querySelector('[name="postal_code"]');
  var debounceTimer;

  function escAttr(s) { return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;'); }
  function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

  streetInput.addEventListener('input', function () {
    clearTimeout(debounceTimer);
    var q = this.value.trim();
    if (q.length < 2) {
      suggestionsEl.style.display = 'none';
      suggestionsEl.innerHTML = '';
      return;
    }
    debounceTimer = setTimeout(function () {
      fetch('/client/addresses/autocomplete?q=' + encodeURIComponent(q))
        .then(function (r) { return r.json(); })
        .then(function (results) {
          if (!results.length) {
            suggestionsEl.style.display = 'none';
            suggestionsEl.innerHTML = '';
            return;
          }
          suggestionsEl.innerHTML = results.map(function (a) {
            var label = escHtml(a.street);
            if (a.city)        label += ', ' + escHtml(a.city);
            if (a.state)       label += ' ' + escHtml(a.state);
            if (a.postal_code) label += ' ' + escHtml(a.postal_code);
            return '<button type="button" class="list-group-item list-group-item-action py-1 small"' +
              ' data-street="'  + escAttr(a.street       || '') + '"' +
              ' data-city="'    + escAttr(a.city         || '') + '"' +
              ' data-state="'   + escAttr(a.state        || '') + '"' +
              ' data-postal="'  + escAttr(a.postal_code  || '') + '"' +
              ' data-country="' + escAttr(a.country      || '') + '">' +
              label + '</button>';
          }).join('');
          suggestionsEl.style.display = '';
        });
    }, 250);
  });

  suggestionsEl.addEventListener('mousedown', function (e) {
    var btn = e.target.closest('button[data-street]');
    if (!btn) return;
    e.preventDefault(); // keep focus on street input long enough to populate
    streetInput.value = btn.dataset.street;
    if (cityEl)   cityEl.value   = btn.dataset.city;
    if (postalEl) postalEl.value = btn.dataset.postal;
    if (btn.dataset.country) {
      countryEl.value = btn.dataset.country;
      applyCountry(btn.dataset.country);
    }
    if (btn.dataset.state) stateEl.value = btn.dataset.state;
    suggestionsEl.style.display = 'none';
  });

  streetInput.addEventListener('blur', function () {
    // small delay so a click on a suggestion fires first
    setTimeout(function () { suggestionsEl.style.display = 'none'; }, 150);
  });

  streetInput.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      suggestionsEl.style.display = 'none';
    }
  });
})();
</script>
