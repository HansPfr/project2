<%- include('../partials/header', { title: 'Phone & Email', navType: 'client' }) %>

<nav aria-label="breadcrumb" class="mb-4">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/client/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item active">Phone & Email</li>
  </ol>
</nav>

<h2 class="mb-4"><i class="bi bi-telephone-fill me-2 text-info"></i>Phone & Email</h2>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const qs = new URLSearchParams(window.location.search);
    const msg = qs.get('success') || qs.get('error');
    if (msg) {
      const el = document.createElement('div');
      el.className = qs.get('error') ? 'alert alert-danger' : 'alert alert-success';
      el.textContent = msg;
      document.querySelector('h2').insertAdjacentElement('afterend', el);
    }
  });
</script>

<!-- Phone Numbers -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4><i class="bi bi-phone me-2"></i>Phone Numbers</h4>
  <button class="btn btn-info text-white" data-bs-toggle="modal" data-bs-target="#addPhoneModal">
    <i class="bi bi-plus-lg me-1"></i>Add Phone
  </button>
</div>

<% if (phones.length === 0) { %>
  <p class="text-muted">No phone numbers added yet.</p>
<% } else { %>
  <div class="table-responsive mb-4">
    <table class="table table-bordered align-middle">
      <thead class="table-light">
        <tr><th>Type</th><th>Number</th><th style="width:160px">Actions</th></tr>
      </thead>
      <tbody>
        <% phones.forEach(p => { %>
          <tr>
            <td><span class="badge bg-secondary"><%= p.type %></span></td>
            <td>
              <% if (p.dial_code) { %><span class="text-muted me-1"><%= p.dial_code %></span><% } %>
              <%= p.number %>
            </td>
            <td>
              <button class="btn btn-sm btn-outline-primary me-1"
                data-bs-toggle="modal" data-bs-target="#editPhone<%= p.id %>">
                <i class="bi bi-pencil"></i>
              </button>
              <form method="post" action="/client/contacts/phones/<%= p.id %>/delete"
                    class="d-inline" onsubmit="return confirm('Delete this phone number?')">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>

          <!-- Edit Phone Modal -->
          <div class="modal fade" id="editPhone<%= p.id %>" tabindex="-1">
            <div class="modal-dialog">
              <div class="modal-content">
                <form method="post" action="/client/contacts/phones/<%= p.id %>/edit">
                  <div class="modal-header">
                    <h5 class="modal-title">Edit Phone Number</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                  </div>
                  <div class="modal-body">
                    <%- include('./phone-fields', { item: p }) %>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<!-- Email Addresses -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4><i class="bi bi-envelope me-2"></i>Email Addresses</h4>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addEmailModal">
    <i class="bi bi-plus-lg me-1"></i>Add Email
  </button>
</div>

<% if (emails.length === 0) { %>
  <p class="text-muted">No email addresses added yet.</p>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-bordered align-middle">
      <thead class="table-light">
        <tr><th>Type</th><th>Address</th><th style="width:160px">Actions</th></tr>
      </thead>
      <tbody>
        <% emails.forEach(e => { %>
          <tr>
            <td><span class="badge bg-secondary"><%= e.type %></span></td>
            <td><%= e.address %></td>
            <td>
              <button class="btn btn-sm btn-outline-primary me-1"
                data-bs-toggle="modal" data-bs-target="#editEmail<%= e.id %>">
                <i class="bi bi-pencil"></i>
              </button>
              <form method="post" action="/client/contacts/emails/<%= e.id %>/delete"
                    class="d-inline" onsubmit="return confirm('Delete this email address?')">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>

          <!-- Edit Email Modal -->
          <div class="modal fade" id="editEmail<%= e.id %>" tabindex="-1">
            <div class="modal-dialog">
              <div class="modal-content">
                <form method="post" action="/client/contacts/emails/<%= e.id %>/edit">
                  <div class="modal-header">
                    <h5 class="modal-title">Edit Email Address</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                  </div>
                  <div class="modal-body">
                    <%- include('./email-fields', { item: e }) %>
                  </div>
                  <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>

<!-- Add Phone Modal -->
<div class="modal fade" id="addPhoneModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="post" action="/client/contacts/phones">
        <div class="modal-header">
          <h5 class="modal-title">Add Phone Number</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <%- include('./phone-fields', { item: {} }) %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-info text-white">Add</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Add Email Modal -->
<div class="modal fade" id="addEmailModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form method="post" action="/client/contacts/emails">
        <div class="modal-header">
          <h5 class="modal-title">Add Email Address</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <%- include('./email-fields', { item: {} }) %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Add</button>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
