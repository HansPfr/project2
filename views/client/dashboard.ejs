<%- include('../partials/header', { title: 'Dashboard', navType: 'client' }) %>

<h2 class="mb-4">My Account</h2>

<div class="row g-4">
  <div class="col-md-4">
    <a href="/client/personal" class="text-decoration-none">
      <div class="card h-100 shadow-sm hover-card">
        <div class="card-body text-center py-4">
          <i class="bi bi-person-fill display-4 text-primary"></i>
          <h5 class="mt-3">Personal Data</h5>
          <p class="text-muted small">Name, date of birth</p>
          <% if (record.first_name) { %>
            <p class="mb-0"><strong><%= record.first_name %> <%= record.last_name %></strong></p>
          <% } else { %>
            <p class="text-muted mb-0 small">Not set yet</p>
          <% } %>
        </div>
      </div>
    </a>
  </div>

  <div class="col-md-4">
    <a href="/client/addresses" class="text-decoration-none">
      <div class="card h-100 shadow-sm hover-card">
        <div class="card-body text-center py-4">
          <i class="bi bi-house-fill display-4 text-success"></i>
          <h5 class="mt-3">Postal Addresses</h5>
          <p class="text-muted small">Home, work and other addresses</p>
        </div>
      </div>
    </a>
  </div>

  <div class="col-md-4">
    <a href="/client/contacts" class="text-decoration-none">
      <div class="card h-100 shadow-sm hover-card">
        <div class="card-body text-center py-4">
          <i class="bi bi-telephone-fill display-4 text-info"></i>
          <h5 class="mt-3">Phone & Email</h5>
          <p class="text-muted small">Phone numbers and email addresses</p>
        </div>
      </div>
    </a>
  </div>
</div>

<%- include('../partials/footer') %>
